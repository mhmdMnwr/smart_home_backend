### login
POST http://localhost:3000/auth/login
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "newsecretpassword"
}

### reset password
POST http://localhost:3000/auth/reset-password
Content-Type: application/json

{
  "email": "test@example.com",
  "previousPassword": "mysecretpassword",
  "newPassword": "newsecretpassword2"
}

### create history
POST http://localhost:3000/history
Content-Type: application/json

{
  "device": "mq2",
  "type": "temperature",
  "value": 22.5
}

### get history by id
GET http://localhost:3000/history/PLACEHOLDER_ID

### get history by type (paginated)
GET http://localhost:3000/history/type/temperature

### get history by type and date (paginated - standard YYYY-MM-DD structure)
GET http://localhost:3000/history/type/temperature/date/2026-04-06?page=1&limit=5

### update device status (online)
POST http://localhost:3000/status/update
Content-Type: application/json

{
  "device": "esp32-living-room",
  "status": "online"
}

### update device status (offline)
POST http://localhost:3000/status/update
Content-Type: application/json

{
  "device": "esp32-living-room",
  "status": "offline"
}

### create notification
POST http://localhost:3000/notifications
Content-Type: application/json

{
  "message": "Smoke detected in kitchen",
  "type": "alert",
  "isread": false
}

### get notifications (paginated, newest first)
GET http://localhost:3000/notifications?page=1&limit=10


### test mqtt publish
post http://localhost:3000/mqtt/publish
Content-Type: application/json

### set lamp 1 (topic smartHome/devices/lamp/lamp1/set)
POST http://localhost:3000/mqtt/setLed/lamp1
Content-Type: application/json

{
  "set": "on"
}

### set lamp 2 (topic smartHome/devices/lamp/lamp2/set)
POST http://localhost:3000/mqtt/setLed/lamp2
Content-Type: application/json

{
  "set": "on"
}

### set fan 1 (topic smartHome/devices/fan/fan1/set)
POST http://localhost:3000/mqtt/setfan/fan1
Content-Type: application/json

{
  "set": "off"
}

### set fan 2 (topic smartHome/devices/fan/fan2/set)
POST http://localhost:3000/mqtt/setfan/fan1
Content-Type: application/json

{
  "set": "off"
}

### open door (topic smartHome/devices/door/opendoor)
POST http://localhost:3000/mqtt/opendoor
Content-Type: application/json

{
  "password": "your-secret-password"
}

### open door (topic smartHome/devices/door/opendoor)
POST http://localhost:3000/mqtt/setAlarm
Content-Type: application/json

{
 "set": "off"
}




### sub to a topic
post http://localhost:3000/mqtt/subscribe
Content-Type: application/json